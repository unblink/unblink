# Relay Configuration

APP_DIR=./data
RELAY_PORT=9020
API_PORT=8020
DASHBOARD_URL=http://localhost:3000
JWT_SECRET=dev-secret-key-do-not-use-in-production
DEV_IMPERSONATE_EMAIL=

# Auto-Streaming Configuration
AUTOSTREAM_ENABLED=false
FRAME_INTERVAL_SECONDS=5.0
FRAME_BATCH_SIZE=10
AUTOSTREAM_OPENAI_TIMEOUT=30
AUTOSTREAM_OPENAI_MODEL=Qwen/Qwen3-VL-4B-Instruct
AUTOSTREAM_OPENAI_API_KEY=
AUTOSTREAM_OPENAI_BASE_URL=https://vllm.unblink.net/v1

# Video Recording Configuration
VIDEO_RECORDING_ENABLED=false
VIDEO_SEGMENT_DURATION_MINUTES=5.0

# Chat-RPC Configuration
CHAT_OPENAI_MODEL=Qwen/Qwen3-VL-4B-Instruct
CHAT_OPENAI_API_KEY=
CHAT_OPENAI_BASE_URL=https://vllm.unblink.net/v1

# Admin User Configuration (Initial Setup)
ADMIN_EMAIL=admin@unblink.net
ADMIN_PASSWORD=admin-password-change-me
