{
  // Relay server WebSocket URL
  // Development: "ws://localhost:9020/node/connect"
  // Production: "wss://relay.unblink.net/node/connect"
  "relay_address": "wss://relay.unblink.net/node/connect",

  // Authorization token (added after authorization)
  "token": "",

  // Services to expose through this node
