      "port": 1554,
      "path": "/cam58"
      // "auth": {
      //   "type": "username_and_password",
      //   "username": "****",
      //   "password": "****"
      // }
    },
    {
      "name": "Parking Lot",
      "type": "mjpeg",
      "addr": "83.48.75.113",
      "port": 8320,
      "path": "/axis-cgi/mjpg/video.cgi"
    }
  ]
}
